<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PCM 录音机"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- 录音控制 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnRecord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开始录音"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnStopRecord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停止录音" />
    </LinearLayout>

    <!-- 播放控制 -->
    <LinearLayout
        android:layout_width="388dp"
        android:layout_height="148dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="播放" />

        <Button
            android:id="@+id/btnStopPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停止播放" />

    </LinearLayout>

    <!-- 状态显示 -->

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#f0f0f0"
        android:padding="16dp"
        android:text="准备就绪\n格式: 16kHz, 16bit, 单通道 PCM"
        android:textSize="14sp"
        android:minLines="4" />

    <!-- 说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="说明：\n• 录音文件保存在 /Android/data/com.example.audiorecorder/files/AudioRecords/\n• 文件格式: record_16k_16bit_mono.pcm\n• 可用 Audacity 等工具验证 PCM 文件（导入时选择 16kHz, 16bit, 小端, 单通道）"
        android:textSize="12sp"
        android:textColor="#666666" />

</LinearLayout>